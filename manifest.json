{
  "manifest_version": 3,
  "name": "Codeforces Random Problem",
  "version": "1.0",
  "description": "Get random Codeforces problems based on your rating",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://codeforces.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://codeforces.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
